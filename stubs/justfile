# Variables
uid         := `id -u`
gid         := `id -g`
compose_bin := if `command -v docker-compose 2>/dev/null` != "" { "docker-compose" } else { "docker compose" }
compose     := "USER_UID=" + uid + " WWWGROUP=" + gid + " " + compose_bin
sail        := "USER_UID=" + uid + " ./vendor/bin/sail"

# Show available commands
default:
    @just --list

# ── Installation ─────────────────────────────────────────────────────────────

# Install Composer deps via Docker (no local PHP/Composer needed)
build:
    docker run --rm \
        -u "{{ uid }}:{{ gid }}" \
        -v "$(pwd):/var/www/html" \
        -w /var/www/html \
        laravelsail/php84-composer:latest \
        composer install --ignore-platform-reqs

# Full project setup: configure .env, start Sail, install deps, migrate & seed
install name:
    sed -i "s|^APP_NAME=.*|APP_NAME={{ name }}|" .env
    sed -i "s|^APP_URL=.*|APP_URL=http://{{ name }}.local|" .env
    grep -q "^WWWGROUP=" .env \
        && sed -i "s|^WWWGROUP=.*|WWWGROUP={{ gid }}|" .env \
        || echo "WWWGROUP={{ gid }}" >> .env
    @echo "Updated APP_NAME, APP_URL and WWWGROUP in .env ({{ name }})"
    grep -q "{{ name }}.local" /etc/hosts \
        || echo "127.0.0.1\t{{ name }}.local" | sudo tee -a /etc/hosts
    {{ compose }} up --detach
    {{ sail }} composer install
    {{ sail }} artisan key:generate -n
    just install-front
    {{ sail }} artisan migrate:fresh --seed

# Install / rebuild frontend assets
install-front:
    {{ sail }} npm install
    {{ sail }} npm run build

# ── Docker ───────────────────────────────────────────────────────────────────

# Start containers in the background
up:
    {{ compose }} up --detach

# Stop containers
down:
    {{ compose }} stop

# Open a shell in the app container
shell:
    {{ sail }} bash

# ── Artisan ──────────────────────────────────────────────────────────────────

# Run any artisan command  e.g. just artisan "route:list --json"
artisan cmd:
    {{ sail }} php artisan {{ cmd }}

# Fresh migrate + seed
fresh:
    {{ sail }} php artisan migrate:fresh --seed

# Rollback last migration batch
migrate-rollback:
    {{ sail }} php artisan migrate:rollback

# Open Tinker REPL
tinker:
    {{ sail }} php artisan tinker

# Clear all caches (config, route, view, application)
cache-clear:
    {{ sail }} php artisan config:clear
    {{ sail }} php artisan route:clear
    {{ sail }} php artisan view:clear
    {{ sail }} php artisan cache:clear

# Generate IDE helper model docblocks
ide:
    {{ sail }} php artisan ide-helper:model -M

# ── Code Quality ─────────────────────────────────────────────────────────────

# Run PHPStan static analysis
phpstan:
    {{ sail }} php ./vendor/bin/phpstan analyse --memory-limit=2G

# Fix code style with Pint  (pass check=true for dry-run, e.g. just pint true)
pint check="":
    {{ sail }} php ./vendor/bin/pint {{ if check != "" { "--test" } else { "" } }}

# Run Pint + PHPStan
lint:
    just pint
    just phpstan

# ── Testing ──────────────────────────────────────────────────────────────────

# Run tests  (optionally filter a single test: just test MyTestClass)
test filter="":
    {{ sail }} php artisan test {{ if filter != "" { "--filter=" + filter } else { "--parallel" } }}

# Run tests with code coverage report (HTML in build/coverage/)
test-coverage:
    {{ sail }} php -d xdebug.mode=coverage ./vendor/bin/paratest --coverage-html build/coverage

# ── Composite ────────────────────────────────────────────────────────────────

# Lint + test
check:
    just lint
    just test

# Full pre-commit workflow: fresh migrate → IDE helpers → lint → test
pre-commit:
    just fresh
    just ide
    just check

# ── Deployment ───────────────────────────────────────────────────────────────

# Run full server provisioning for an environment  e.g. just provision staging
provision env:
    {{ sail }} ./vendor/bin/dep provision {{ env }}

# Set GitHub Secrets for an environment via gh CLI  e.g. just secrets staging
# Requires: gh auth login (run locally before starting Sail)
secrets env:
    {{ sail }} ./vendor/bin/dep provision:github-secrets {{ env }}

# Deploy to an environment  e.g. just deploy staging
deploy env:
    {{ sail }} ./vendor/bin/dep deploy {{ env }}
